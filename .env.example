# Team Office Hub — copy to .env for local overrides (do not commit .env)

# Persistent data (SQLite + bridge jsonl). Use /data on cloud with a volume.
DATA_DIR=

# Comma-separated origins for CORS (GitHub Pages + local)
ALLOWED_ORIGINS=http://127.0.0.1:8765,http://localhost:8765,https://tanitsu-reberu.github.io

# API token — required for /api/cursor/* (E4). Auto-generated by launch-office.ps1
HUB_TOKEN=

# Cursor API sandbox: 1 = /api/cursor/* only from localhost (default)
CURSOR_API_LOCALHOST_ONLY=1

# Server port (Railway/Render inject PORT automatically)
PORT=8765